# Bearer token for the local Express API at /Users/Emile/developments/harmoney/ai-agents/
# This is read by the Next.js server route at /api/proxy/* and is never sent to the browser.
HARMONEY_API_KEY=replace-with-a-key-from-API_KEYS-in-the-root-.env

# Upstream API base URL (no trailing slash, includes /v1)
HARMONEY_API_URL=http://localhost:3000/v1
